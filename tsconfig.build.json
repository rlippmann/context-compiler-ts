{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": false,
    "types": []
  },
  "include": [
    "index.ts",
    "src/**/*.ts",
    "examples/*.ts",
    "examples/integrations/**/*.ts",
    "demos/**/*.ts",
    "demos/**/*.d.ts"
  ],
  "exclude": ["tests", "dist", "node_modules"]
}
